{
  "name": "@gabon-biz/database",
  "version": "0.1.0",
  "private": true,
  "description": "GABON BIZ - Prisma schema et client database",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
