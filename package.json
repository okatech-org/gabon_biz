{
  "name": "gabon-biz",
  "version": "0.1.0",
  "private": true,
  "description": "GABON BIZ — Super-application économique et entrepreneuriale du Gabon",
  "author": "NTSAGUI Digital & OKA Tech",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter './services/*' --parallel run dev",
    "dev:auth": "pnpm --filter @gabon-biz/mock-oidc dev",
    "dev:full": "concurrently \"pnpm dev:auth\" \"pnpm dev:web\"",
    "test:kong": "bash apps/api-gateway/test-kong.sh",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm -r run test:e2e",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter database prisma generate",
    "db:migrate": "pnpm --filter database prisma migrate dev",
    "db:seed": "pnpm --filter database prisma db seed",
    "convex:dev": "pnpm --filter web npx convex dev",
    "convex:deploy": "pnpm --filter web npx convex deploy",
    "deploy:cloudrun": "gcloud builds submit apps/web --tag gcr.io/gabon-biz/gabon-biz-web --project=gabon-biz && gcloud run deploy gabon-biz-web --image gcr.io/gabon-biz/gabon-biz-web --platform managed --region europe-west1 --allow-unauthenticated --port 8080 --project=gabon-biz",
    "deploy:firebase": "firebase deploy --only hosting --project gabon-biz",
    "docker:dev": "docker compose -f infra/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.dev.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
